,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\index.tsx",[],["84","85"],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\store\\store.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\services\\mirage\\server.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\store\\rootReducer.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\services\\mirage\\routes\\diary.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\services\\mirage\\routes\\user.tsx",["86"],"import { Response,Request } from 'miragejs';\r\nimport { handleErrors } from '../server';\r\nimport { randomBytes } from 'crypto'\r\nimport { User } from '../../../interfaces/user.interface';\r\n\r\nconst generateToken =()=> randomBytes(8).toString('hex');\r\n\r\nexport interface AuthResponse {\r\n    token: string;\r\n    user: User\r\n};\r\n\r\nconst login = (schema:any, req: Request): AuthResponse | Response => {\r\n    const {username, password} = JSON.parse(req.requestBody);\r\n    const user = schema.users.findBy({username});\r\n    if(!user) {\r\n        return handleErrors(null, \"Password is incorrect.\");\r\n    }\r\n    if(password !== user.password) {\r\n        return handleErrors(null, 'password is incorrect.')\r\n    }\r\n    const token = generateToken();\r\n    return{\r\n        user: user.attrs as User,\r\n        token,\r\n    };\r\n};\r\nconst signup = (schema: any, req: Request): AuthResponse | Response => {\r\n    const data = JSON.parse(req.requestBody);\r\n    const exUser = schema.users.findBy({username: data.username});\r\n    if(exUser){\r\n        return handleErrors(null, \"A user with that username already exist.\")\r\n    }\r\n    const user = schema.users.create(data);\r\n    const token = generateToken();\r\n    return{\r\n        user: user.attrs as User,\r\n        token,\r\n    };\r\n};\r\nexport default {\r\n    login,\r\n    signup,\r\n}","C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\entry\\entrySlice.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\entry\\editorSlice.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\auth\\userSlice.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\auth\\authSlice.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\diary\\diarySlice.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\App\\App.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\home\\Home.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\entry\\Editor.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\diary\\Diaries.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\diary\\DiaryTile.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\util.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\diary\\DiariesEntries.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\services\\API.tsx",[],"C:\\Users\\home\\Downloads\\React_Repos\\Diaries-APP\\diaries\\src\\features\\auth\\Auth.tsx",[],{"ruleId":"87","replacedBy":"88"},{"ruleId":"89","replacedBy":"90"},{"ruleId":"91","severity":1,"message":"92","line":41,"column":1,"nodeType":"93","endLine":44,"endColumn":2},"no-native-reassign",["94"],"no-negated-in-lhs",["95"],"import/no-anonymous-default-export","Assign object to a variable before exporting as module default","ExportDefaultDeclaration","no-global-assign","no-unsafe-negation"]